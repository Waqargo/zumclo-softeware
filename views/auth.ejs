<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zumclo | Partner Access</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=MuseoModerno:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #001F3F;
            --cream: #F5F5DC;
            --accent: #e5e5c7;
            --white: #ffffff;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            font-family: 'Inter', sans-serif;
            background-color: var(--navy);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* The Main Glass Card */
        .auth-card {
            background: var(--cream);
            width: 90%;
            max-width: 450px;
            padding: 50px 40px;
            border-radius: 40px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            text-align: center;
            position: relative;
            z-index: 10;
        }

        .logo {
            font-family: 'MuseoModerno', cursive;
            font-size: 3rem;
            color: var(--navy);
            margin-bottom: 10px;
            letter-spacing: -2px;
        }

        .subtitle {
            color: #666;
            font-size: 0.9rem;
            margin-bottom: 40px;
            font-weight: 500;
        }

        /* Form Styling */
        form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .input-group {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-group i {
            position: absolute;
            left: 15px;
            color: var(--navy);
            opacity: 0.5;
            width: 18px;
        }

        .auth-input {
            width: 100%;
            padding: 16px 16px 16px 45px;
            border: 2px solid transparent;
            background: var(--white);
            border-radius: 15px;
            font-family: inherit;
            font-size: 1rem;
            transition: var(--transition);
            box-sizing: border-box;
        }

        .auth-input:focus {
            outline: none;
            border-color: var(--navy);
            box-shadow: 0 0 0 4px rgba(0, 31, 63, 0.05);
        }

        .btn-primary {
            background: var(--navy);
            color: var(--cream);
            padding: 16px;
            border: none;
            border-radius: 15px;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 10px;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 31, 63, 0.2);
        }

        /* Toggle Logic */
        .toggle-text {
            margin-top: 25px;
            font-size: 0.85rem;
            color: #777;
        }

        .toggle-link {
            color: var(--navy);
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
        }

        .hidden { display: none; }

        /* Background Decorations */
        .bg-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(245, 245, 220, 0.05);
            z-index: 1;
        }
    </style>
</head>
<body>

    <div class="bg-circle" style="width: 400px; height: 400px; top: -100px; left: -100px;"></div>
    <div class="bg-circle" style="width: 300px; height: 300px; bottom: -50px; right: -50px;"></div>

    <div class="auth-card">
        <div class="logo">zumclo</div>
        
        <div id="login-section">
            <p class="subtitle">Welcome back, Partner.</p>
            <form action="/login" method="POST">
                <div class="input-group">
                    <i data-lucide="user"></i>
                    <input type="text" name="username" class="auth-input" placeholder="Username" required>
                </div>
                <div class="input-group">
                    <i data-lucide="lock"></i>
                    <input type="password" name="password" class="auth-input" placeholder="Password" required>
                </div>
                <button type="submit" class="btn-primary">Authorized Entry</button>
            </form>
            <p class="toggle-text">New partner? <span class="toggle-link" onclick="toggleAuth()">Create Account</span></p>
        </div>

        <div id="signup-section" class="hidden">
            <p class="subtitle">Register new business access.</p>
            <form action="/register" method="POST">
                <div class="input-group">
                    <i data-lucide="user"></i>
                    <input type="text" name="username" class="auth-input" placeholder="Choose Username" required>
                </div>
                <div class="input-group">
                    <i data-lucide="mail"></i>
                    <input type="email" name="email" class="auth-input" placeholder="Email Address" required>
                </div>
                <div class="input-group">
                    <i data-lucide="shield-check"></i>
                    <input type="password" name="password" class="auth-input" placeholder="Secure Password" required>
                </div>
                <button type="submit" class="btn-primary">Register Access</button>
            </form>
            <p class="toggle-text">Already registered? <span class="toggle-link" onclick="toggleAuth()">Sign In</span></p>
        </div>
    </div>

    <script>
        lucide.createIcons();

        function toggleAuth() {
            const loginSection = document.getElementById('login-section');
            const signupSection = document.getElementById('signup-section');
            
            loginSection.classList.toggle('hidden');
            signupSection.classList.toggle('hidden');
        }
    </script>
</body>
</html>