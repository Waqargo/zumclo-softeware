<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zumclo | <%= status %></title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=MuseoModerno:wght@400;700&family=Inter:wght@300;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #F5F5DC;
            --navy: #001F3F;
            --accent: #e67e22;
        }

        body {
            background-color: var(--navy);
            color: var(--cream);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            text-align: center;
        }

        .error-card {
            padding: 50px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(245, 245, 220, 0.1);
            border-radius: 40px;
            backdrop-filter: blur(20px);
            max-width: 450px;
            width: 90%;
        }

        .status-code {
            font-family: 'MuseoModerno';
            font-size: 6rem;
            margin: 0;
            line-height: 1;
            background: linear-gradient(to bottom, #F5F5DC, #8a8a7b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            opacity: 0.9;
        }

        h2 { margin: 10px 0; font-weight: 500; letter-spacing: 1px; }
        p { opacity: 0.6; line-height: 1.6; margin-bottom: 30px; }

        .btn-back {
            background: var(--cream);
            color: var(--navy);
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

        .btn-back:hover { transform: scale(1.05); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
    </style>
</head>
<body>
    <div class="error-card">
        <h1 class="status-code"><%= status %></h1>
        <h2><%= title %></h2>
        <p><%= message %></p>
        
        <a href="/" class="btn-back">
            <i data-lucide="home" size="18"></i>
            Back to Dashboard
        </a>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>