<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zumclo | Funds</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=MuseoModerno:wght@400;700&family=Inter:wght@400;700;800&display=swap" rel="stylesheet">
    
    <%- include('partials/navbar') %>

    <style>
        :root { 
            --cream: #F5F5DC; 
            --navy: #001F3F; 
            --white: #ffffff; 
            --red: #c0392b; 
            --green: #27ae60; 
            --accent: #e5e5c7; 
        }

        body { 
            background-color: var(--cream); 
            font-family: 'Inter', sans-serif; 
            color: var(--navy); 
            padding-top: 100px; 
            margin: 0;
        }

        .container { 
            max-width: 1100px; 
            margin: 0 auto; 
            padding: 20px; 
            box-sizing: border-box; 
        }
        
        /* Summary Card */
        .summary-card { 
            background: var(--navy); 
            color: var(--cream); 
            padding: 30px; 
            border-radius: 25px; 
            text-align: center; 
            margin-bottom: 30px; 
            box-shadow: 0 10px 30px rgba(0,31,63,0.1); 
        }

        .target-box { 
            display: flex; 
            justify-content: space-around; 
            margin-top: 20px; 
            border-top: 1px solid rgba(245,245,220,0.2); 
            padding-top: 20px; 
        }

        /* Debt Grid */
        .debt-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
            gap: 25px; 
            margin-bottom: 40px; 
        }

        .person-card { 
            background: var(--white); 
            padding: 30px; 
            border-radius: 24px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            display: flex;
            flex-direction: column;
            transition: all 0.3s ease;
            border: 2px solid transparent;
        }

        .person-card:hover {
            transform: translateY(-8px);
            border-color: var(--accent);
        }

        .status-tag { 
            padding: 8px 15px; 
            border-radius: 12px; 
            font-size: 0.75rem; 
            font-weight: 800; 
            text-transform: uppercase; 
            letter-spacing: 0.5px; 
        }
        
        /* Transfer Section */
        .transfer-section { 
            background: var(--white); 
            padding: 35px; 
            border-radius: 25px; 
            margin-bottom: 40px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.03); 
        }

        .transfer-form { 
            display: flex; 
            gap: 20px; 
            flex-wrap: wrap; 
            align-items: flex-end; 
        }

        .t-input { 
            flex: 1; 
            min-width: 200px; 
            display: flex; 
            flex-direction: column; 
            gap: 8px; 
        }

        .t-input label { 
            font-size: 0.7rem; 
            font-weight: 800; 
            color: #888; 
            letter-spacing: 1px; 
        }

        .t-input input, .t-input select { 
            width: 100%; 
            padding: 14px; 
            border: 2px solid #f0f0f0; 
            border-radius: 12px; 
            font-family: inherit; 
            box-sizing: border-box; 
            transition: border-color 0.3s;
        }

        .t-input input:focus, .t-input select:focus {
            border-color: var(--navy);
            outline: none;
        }
        
        .btn-transfer { 
            background: var(--navy); 
            color: var(--cream); 
            padding: 15px 30px; 
            border: none; 
            border-radius: 12px; 
            font-weight: 700; 
            cursor: pointer; 
            transition: 0.3s; 
            min-width: 180px; 
        }

        .btn-transfer:hover { 
            background: #002d5c; 
            transform: scale(1.02); 
        }
        
        /* Table container */
        .history-container { 
            background:var(--white); 
            border-radius: 24px; 
            padding: 15px 25px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.05); 
            overflow-x: auto; 
        }

        .history-mini-table { 
            width: 100%; 
            border-collapse: collapse; 
            font-size: 0.9rem; 
            min-width: 500px; 
        }

        .history-mini-table td { 
            padding: 16px 10px; 
            border-bottom: 1px solid #f8f8f8; 
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            .target-box { flex-direction: column; gap: 20px; }
            .target-box > div { border-left: none !important; padding-left: 0 !important; }
            .t-input { min-width: 100%; }
            .btn-transfer { width: 100%; }
            body { padding-top: 90px; }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="summary-card">
        <h1 style="font-family: MuseoModerno; margin:0; letter-spacing: -1px;">Settlement Hub</h1>
        <p style="opacity: 0.7; font-size: 0.9rem; margin-top: 5px;">Business Expenditure vs Individual Investment</p>
        <div class="target-box">
            <div>
                <div style="font-size: 0.65rem; opacity: 0.7; font-weight: 800; letter-spacing: 1px;">TOTAL SPENT</div>
                <div style="font-size: 1.8rem; font-weight: 700;">PKR <%= stats.totalSpent.toLocaleString() %></div>
            </div>
            <div style="border-left: 1px solid rgba(245,245,220,0.2); padding-left: 20px;">
                <div style="font-size: 0.65rem; opacity: 0.7; font-weight: 800; letter-spacing: 1px;">EQUAL SHARE (1/3)</div>
                <div style="font-size: 1.8rem; font-weight: 700;">PKR <%= perPersonTarget.toLocaleString() %></div>
            </div>
        </div>
    </div>

    <div class="debt-grid">
        <% partners.forEach(name => { 
            let totalContributed = (stats.spending[name] || 0) + (stats.investment[name] || 0);
            let balance = totalContributed - perPersonTarget;
        %>
            <div class="person-card">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                    <h3 style="font-family: MuseoModerno; margin:0; font-size: 1.4rem;"><%= name %></h3>
                    <% if(balance >= 0) { %>
                        <span class="status-tag" style="background: #eafaf1; color: var(--green);">Owed</span>
                    <% } else { %>
                        <span class="status-tag" style="background: #fdedec; color: var(--red);">Owes</span>
                    <% } %>
                </div>
                
                <div style="font-size: 0.9rem; color: #555; line-height: 2;">
                    Spending: <strong style="float:right;">PKR <%= (stats.spending[name] || 0).toLocaleString() %></strong><br>
                    <!-- Internal/Capital: <strong style="float:right;">PKR <%= (stats.investment[name] || 0).toLocaleString() %></strong><br> -->
                    <div style="border-top:1px solid #f0f0f0; margin-top:10px; padding-top:5px; font-weight: 700; color: var(--navy);">
                        Total Spent: <span style="float:right;">PKR <%= totalContributed.toLocaleString() %></span>
                    </div>
                </div>

                <div style="margin-top:25px; padding:20px; background: #fafafa; border-radius: 15px; text-align: center;">
                    <div style="font-size: 0.7rem; color: #999; font-weight: 800; margin-bottom: 5px; letter-spacing: 1px;">NET SETTLEMENT</div>
                    <div style="font-size: 1.5rem; font-weight: 800; color: <%= balance >= 0 ? 'var(--green)' : 'var(--red)' %>">
                        PKR <%= Math.abs(balance).toLocaleString() %>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <div class="transfer-section">
        <h3 style="font-family: MuseoModerno; margin-top:0; font-size: 1.3rem;">Record Fund Entry</h3>
        <form action="/add-fund" method="POST" class="transfer-form">
            <div class="t-input">
                <label>FROM (SENDER)</label>
                <select name="from" required>
                    <% partners.forEach(p => { %><option value="<%= p %>"><%= p %></option><% }) %>
                    <option value="Business">Business</option>
                </select>
            </div>
            <div class="t-input">
                <label>TO (RECEIVER)</label>
                <select name="to" required>
                    <option value="Business">Business (Direct Capital)</option>
                    <% partners.forEach(p => { %><option value="<%= p %>"><%= p %></option><% }) %>
                </select>
            </div>
            <div class="t-input">
                <label>AMOUNT (PKR)</label>
                <input type="number" name="amount" step="1" required placeholder="0">
            </div>
            <div class="t-input">
                <label>DATE</label>
                <input type="date" name="date" required value="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <button type="submit" class="btn-transfer">Log Transaction</button>
        </form>
    </div>

    <h2 style="font-weight: 300; margin-bottom: 20px; font-family: MuseoModerno;">Recent Transfers</h2>
    <div class="history-container">
        <% if (funds.length > 0) { %>
            <table class="history-mini-table">
                <% funds.forEach(f => { %>
                    <tr>
                        <td style="color:#888; width: 100px; font-weight: 500;"><%= moment(f.date).format('DD MMM') %></td>
                        <td>
                            <span style="color:var(--navy); font-weight:700;"><%= f.from %></span> 
                            <span style="color:#999; font-size: 0.8rem; margin: 0 5px;">→</span> 
                            <span style="color:var(--navy); font-weight:700;"><%= f.to %></span>
                        </td>
                        <td style="text-align: right; font-weight: 800; color: var(--navy);">PKR <%= f.amount.toLocaleString() %></td>
                    </tr>
                <% }) %>
            </table>
        <% } else { %>
            <p style="text-align: center; padding: 20px; opacity: 0.5;">No fund entries recorded yet.</p>
        <% } %>
    </div>
</div>

<script>lucide.createIcons();</script>
</body>
</html>