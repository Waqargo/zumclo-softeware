<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zumclo | Access Denied</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link href="https://fonts.googleapis.com/css2?family=MuseoModerno:wght@400;700&family=Inter:wght@300;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --cream: #F5F5DC;
            --navy: #001F3F;
            --accent: #e67e22; /* Admin orange */
        }

        body {
            background-color: var(--navy);
            color: var(--cream);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
        }

        .error-container {
            text-align: center;
            padding: 60px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(245, 245, 220, 0.1);
            border-radius: 30px;
            backdrop-filter: blur(15px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
            max-width: 500px;
            width: 90%;
        }

        .icon-circle {
            width: 80px;
            height: 80px;
            background: rgba(231, 76, 60, 0.1);
            color: #e74c3c;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
        }

        h1 {
            font-family: 'MuseoModerno';
            font-size: 3rem;
            margin: 0;
            letter-spacing: -2px;
        }

        p {
            opacity: 0.7;
            font-size: 1.1rem;
            line-height: 1.6;
            margin: 20px 0 35px;
        }

        .btn-home {
            background: var(--cream);
            color: var(--navy);
            text-decoration: none;
            padding: 15px 35px;
            border-radius: 12px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: transform 0.2s, background 0.2s;
        }

        .btn-home:hover {
            transform: translateY(-3px);
            background: #fff;
        }

        .bg-glow {
            position: absolute;
            width: 300px;
            height: 300px;
            background: var(--cream);
            filter: blur(150px);
            opacity: 0.05;
            z-index: -1;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
        }
    </style>
</head>
<body>
    <div class="bg-glow"></div>
    
    <div class="error-container">
        <div class="icon-circle">
            <i data-lucide="shield-alert" size="40"></i>
        </div>
        
        <h1>403</h1>
        <p>
            <%= typeof message !== 'undefined' ? message : "You don't have the required permissions to view this partner resource." %>
        </p>

        <a href="/" class="btn-home">
            <i data-lucide="arrow-left" size="18"></i>
            Back to Dashboard
        </a>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>